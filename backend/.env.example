MONGO_URL=mongodb+srv://example_user:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=opositores_db
JWT_SECRET_KEY=your-secret-key-change-in-production-min-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Firebase Auth -- identidad de usuarios (login) vive aquí, no en Mongo.
# Producción: JSON completo de la cuenta de servicio (Firebase Console > Configuración del
# proyecto > Cuentas de servicio > Generar nueva clave privada), pegado como una sola línea.
# Nunca commitear el JSON real ni el .env con este valor relleno.
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_SERVICE_ACCOUNT_JSON=
# Dev/staging sin credenciales reales: deja FIREBASE_SERVICE_ACCOUNT_JSON vacío y usa esto en su
# lugar (requiere el emulador de Firebase Auth corriendo, ver README.md)
FIREBASE_AUTH_EMULATOR_HOST=
