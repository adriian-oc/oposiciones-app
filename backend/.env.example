MONGO_URL=mongodb+srv://example_user:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=opositores_db
JWT_SECRET_KEY=your-secret-key-change-in-production-min-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=43200

# URL pública del frontend, usada para construir los enlaces de restablecimiento de contraseña
# que el admin genera y comparte manualmente con el usuario.
FRONTEND_BASE_URL=http://localhost:3000

# Avisos por email de mensajes nuevos (Brevo, plan gratuito). Sin BREVO_API_KEY, el envío se
# omite silenciosamente -- no hace falta configurarlo en desarrollo local.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=oposicionesadoc@gmail.com
BREVO_SENDER_NAME=ADOC

# Almacenamiento persistente de avatares/documentos/adjuntos de chat en Cloudflare R2 (ver
# services/storage_service.py). Sin R2_ACCOUNT_ID, cae de vuelta a disco local (uploads/) -- no
# hace falta configurarlo en desarrollo local, pero en producción SÍ, porque el disco de Render
# no es persistente entre reinicios.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=adoc-uploads
R2_PUBLIC_URL=
