# URL del backend desplegado (Render/Railway/Fly...)
REACT_APP_API_URL=https://tu-backend.onrender.com

# Config del proyecto de Firebase (Firebase Console > Configuración del proyecto > General >
# Tus apps > Configuración del SDK). apiKey no es secreta, es pública por diseño de Firebase.
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=tu-proyecto

# Solo para desarrollo local contra el emulador -- dejar vacío en producción
REACT_APP_FIREBASE_AUTH_EMULATOR_HOST=
